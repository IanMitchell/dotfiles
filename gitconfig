[user]
	name = Ian Mitchell
	email = ian.mitchell@hey.com

[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process

[core]
	pager = delta
	editor = "nvim"

[delta]
	plus-style = "syntax #012800"
	minus-style = "normal #340001"
	syntax-theme = Monokai Extended
	side-by-side = true
	navigate = true

[interactive]
	diffFilter = delta --color-only

[init]
	defaultBranch = main

[fetch]
	prune = true

[pull]
	rebase = true

[rebase]
	updateRefs = true

[rerere]
	enabled = true

[diff]
	colorMoved = zebra

[push]
	autoSetupRemote = 1

[merge]
	conflictStyle = zdiff3

[url "\"git@github.com:\""]
	insteadOf = \"https://github.com/\"
